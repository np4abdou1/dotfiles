<?xml version="1.0" encoding="UTF-8"?>
<kcfg xmlns="http://www.kde.org/standards/kcfg/1.0"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.kde.org/standards/kcfg/1.0
                          http://www.kde.org/standards/kcfg/1.0/kcfg.xsd">

    <kcfgfile name="plasmarc"/>

    <group name="General">
        <entry name="leftClickAction" type="Int">
            <label>Left Click Action</label>
            <default>0</default>
        </entry>
        <entry name="leftClickAppValue" type="String">
            <label>Left Click App Command</label>
            <default>plasma-systemmonitor</default>
        </entry>
        <entry name="leftClickUrlValue" type="String">
            <label>Left Click URL</label>
            <default></default>
        </entry>
        <entry name="leftClickCmdValue" type="String">
            <label>Left Click Command</label>
            <default></default>
        </entry>
        <entry name="itemSpacing" type="Int">
            <label>Item Spacing</label>
            <default>8</default>
        </entry>
        <entry name="iconTextSpacing" type="Int">
            <label>Icon Text Spacing</label>
            <default>4</default>
        </entry>
        <entry name="horizontalPadding" type="Int">
            <label>Horizontal Padding</label>
            <default>0</default>
        </entry>
        <entry name="verticalPadding" type="Int">
            <label>Vertical Padding</label>
            <default>0</default>
        </entry>
        <entry name="fontSize" type="Int">
            <label>Font Size</label>
            <default>10</default>
        </entry>
        <entry name="fontFamily" type="String">
            <label>Font Family</label>
            <default></default>
        </entry>
        <entry name="showIcons" type="Bool">
            <label>Show Icons</label>
            <default>true</default>
        </entry>
        <entry name="panelLayout" type="String">
            <label>Panel Layout Grid String</label>
            <default>cpu|gpu|ram|swap|upload|download</default>
        </entry>
        <entry name="useFixedWidth" type="Bool">
            <label>Use Fixed Width</label>
            <default>false</default>
        </entry>
        <entry name="widgetWidth" type="Int">
            <label>Widget Width</label>
            <default>400</default>
        </entry>
        <entry name="bgOpacity" type="Int">
            <label>Background Opacity</label>
            <default>50</default>
        </entry>
        <entry name="cpuColor" type="Color">
            <label>CPU Color</label>
            <default>#ffffff</default>
        </entry>
        <entry name="gpuColor" type="Color">
            <label>GPU Color</label>
            <default>#ffffff</default>
        </entry>
        <entry name="ramColor" type="Color">
            <label>RAM Color</label>
            <default>#ffffff</default>
        </entry>
        <entry name="swapColor" type="Color">
            <label>Swap Color</label>
            <default>#ffffff</default>
        </entry>
        <entry name="uploadColor" type="Color">
            <label>Upload Color</label>
            <default>#ffffff</default>
        </entry>
        <entry name="downloadColor" type="Color">
            <label>Download Color</label>
            <default>#ffffff</default>
        </entry>
        <entry name="cpuTempColor" type="Color">
            <label>CPU Temp Color</label>
            <default>#ffffff</default>
        </entry>
        <entry name="gpuTempColor" type="Color">
            <label>GPU Temp Color</label>
            <default>#ffffff</default>
        </entry>
        <entry name="vramColor" type="Color">
            <label>VRAM Color</label>
            <default>#ffffff</default>
        </entry>
        <entry name="batteryColor" type="Color">
            <label>Battery Color</label>
            <default>#ffffff</default>
        </entry>
        <entry name="uptimeColor" type="Color">
            <label>Uptime Color</label>
            <default>#ffffff</default>
        </entry>
        <entry name="netSpeedFormat" type="Int">
            <label>Network Speed Format</label>
            <default>0</default>
        </entry>
        <entry name="showTooltips" type="Bool">
            <label>Show Tooltips</label>
            <default>true</default>
        </entry>
        <entry name="customModules" type="String">
            <label>Custom Modules JSON</label>
            <default>[{"id":"cpu","conditions":[{"operator":">=","threshold":"80","color":"#ffa500"},{"operator":">=","threshold":"95","color":"#ff0000"}]},{"id":"gpu","conditions":[{"operator":">=","threshold":"80","color":"#ffa500"},{"operator":">=","threshold":"95","color":"#ff0000"}]},{"id":"ram","conditions":[{"operator":">=","threshold":"80","color":"#ffa500"},{"operator":">=","threshold":"95","color":"#ff0000"}]},{"id":"swap","conditions":[{"operator":">=","threshold":"80","color":"#ffa500"},{"operator":">=","threshold":"95","color":"#ff0000"}]},{"id":"upload","conditions":[{"operator":">=","threshold":"1048576","color":"#00ffff"},{"operator":">=","threshold":"5242880","color":"#00ff00"}]},{"id":"download","conditions":[{"operator":">=","threshold":"1048576","color":"#00ffff"},{"operator":">=","threshold":"5242880","color":"#00ff00"}]}]</default>
        </entry>
    </group>
</kcfg>
